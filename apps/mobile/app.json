{
  "expo": {
    "name": "Cooperative Plus",
    "slug": "cooperative-plus",
    "scheme": "cooperativeplus",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/logo-round.png",
    "backgroundColor": "#ffffff",
    "ios": { "supportsTablet": true, "bundleIdentifier": "ts.mila.cooperativeplus" },
    "android": { "package": "ts.mila.cooperativeplus", "adaptiveIcon": { "foregroundImage": "./assets/logo-round.png", "backgroundColor": "#ffffff" } },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo-round.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
