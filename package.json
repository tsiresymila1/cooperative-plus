{
  "name": "cooperative-plus",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "seed": "pnpm --filter @cp/instant seed",
    "db:push-schema": "instant-cli push schema --app feb5e50f-21d7-4880-9de5-49eba48f2a45 --yes",
    "db:push-perms": "instant-cli push perms --app feb5e50f-21d7-4880-9de5-49eba48f2a45 --yes",
    "dev:web": "turbo run dev --filter=@cp/client --filter=@cp/coop --filter=@cp/admin",
    "client": "pnpm --filter @cp/client dev",
    "coop": "pnpm --filter @cp/coop dev",
    "admin": "pnpm --filter @cp/admin dev",
    "mobile": "pnpm --filter @cp/mobile start"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0",
    "@instantdb/core": "^1.0.49",
    "@instantdb/admin": "^1.0.49",
    "instant-cli": "^0.21.0"
  },
  "engines": { "node": ">=20" },
  "pnpm": {
    "overrides": {
      "@instantdb/core": "1.0.49",
      "@types/react": "^19.2.0",
      "@types/react-dom": "^19.2.0",
      "lightningcss": "1.30.1",
      "@expo/metro-runtime": "55.0.11"
    }
  }
}
